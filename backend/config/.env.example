# Local template only. Do not store real secrets in this file.
# Production secrets must come from Fly/Azure secret managers.

SECRET_KEY=CHANGE_ME
MONGO_URI=CHANGE_ME

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_DEFAULT_SENDER=CHANGE_ME

# Optional runtime settings
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True
LOG_LEVEL=INFO

# JWT/session settings
JWT_ISSUER=predictrix-api
JWT_AUDIENCE=predictrix-mobile
ACCESS_TOKEN_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Distributed rate limiting (set Redis URL in production)
RATE_LIMIT_REDIS_URL=

# Local convenience only (default should remain false)
ALLOW_LOCAL_DOTENV=false
STRICT_RUNTIME_SECRETS=false
TRUSTED_PROXY_COUNT=1

# Runtime role (useful outside Fly process groups)
# APP_PROCESS_ROLE=api
# BACKGROUND_WORKERS_ENABLED=false

# Optional external provider keys
